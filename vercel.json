{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "rewrites": [
    {
      "source": "/api/blob/:path*",
      "destination": "/api/blob/:path*"
    },
    {
      "source": "/api/router",
      "destination": "/api/router"
    },
    {
      "source": "/api/:slug*",
      "destination": "/api/router?slug=:slug*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/router.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "api/_handlers/**"
    },
    "api/blob/**/*.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron-metricool-backfill-posts",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron-metricool-snapshot",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron-generate-daily-brief",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron-metricool-poll",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron-fetch-published-metrics",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron-transcribe-recent-posts",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/process-scheduled-posts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/process-push-queue",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/process-email-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/process-recurring-content",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/send-publish-reminders",
      "schedule": "0 9,17 * * *"
    },
    {
      "path": "/api/process-due-date-notifications",
      "schedule": "0 9,15 * * *"
    },
    {
      "path": "/api/run-madureira-workflows-daily",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
